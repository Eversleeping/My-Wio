WIO_DOMAIN=wio.example.com
POSTGRES_PASSWORD=replace-with-a-long-random-password
WIO_DATABASE_URL=postgres://wio:replace-with-url-encoded-password@postgres:5432/wio?sslmode=disable
WIO_MASTER_KEY=replace-with-base64-encoded-32-byte-key
# Optional direct control-plane endpoint for Agents when a CDN cannot proxy gRPC.
WIO_AGENT_DIAL_ADDRESS=
